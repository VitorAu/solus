{
  "name": "solus",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "docker::compose": "docker compose --env-file .env.dev -f docker-compose.dev.yml up -d",
    "docker::stop": "docker compose stop",
    "drizzle::generate-dev": "dotenv -e .env.dev -- yarn workspace @repo/database generate",
    "drizzle::generate-prod": "dotenv -e .env.prod -- yarn workspace @repo/database generate",
    "drizzle::migrate-dev": "dotenv -e .env.dev -- yarn workspace @repo/database migrate",
    "drizzle::migrate-prod": "dotenv -e .env.prod -- yarn workspace @repo/database migrate",
    "app::dev": "turbo run dev",
    "app::prod": "turbo run prod",
    "app::build": "turbo run build",
    "app::format-write": "prettier --write \"**/*.{ts,tsx,md}\"",
    "app::format-check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "app::test": "turbo run test"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "cross-env": "^10.1.0",
    "drizzle-orm": "^0.45.1"
  }
}
