{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "generate": {
      "cache": false
    },
    "migrate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "prod": {
      "cache": false,
      "persistent": true
    },
    "test": {}
  }
}
